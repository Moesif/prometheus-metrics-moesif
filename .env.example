# Moesif Management API Key (required)
# Found in Moesif Dashboard > Settings > Management API Keys
MOESIF_MANAGEMENT_API_KEY=your-management-api-key-here

# Moesif API base URL (optional, defaults to https://api.moesif.com)
MOESIF_API_BASE_URL=https://api.moesif.com

# Server port (optional, defaults to 9277)
PORT=9277

# How far back to query Moesif on each scrape, in seconds (optional, defaults to 60)
# Should match your Prometheus scrape_interval
MOESIF_QUERY_WINDOW_SECONDS=60

# Delay the query window by this many seconds to account for data processing
# delays and eventual consistency in Moesif (optional, defaults to 0)
# For example, with delay=10 and window=60, each scrape queries [now-70s, now-10s]
MOESIF_QUERY_DELAY_SECONDS=0
